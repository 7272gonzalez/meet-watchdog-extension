{
  "manifest_version": 3,
  "name": "Meet Watchdog",
  "version": "1.1.0",
  "description": "Alerts you when a Google Meet, Zoom, or Teams call is active but you haven't joined.",

  "key": "",

  "permissions": [
    "alarms",
    "notifications",
    "tabs",
    "storage",
    "identity",
    "offscreen"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },

  "host_permissions": [
    "https://www.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "253148053376-24b99eu9karatugtr0tkhuali8aout5l.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
